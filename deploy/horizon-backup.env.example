# Horizon — variables d'environnement pour les scripts backup.
#
# Ce fichier est destiné à être copié dans /etc/horizon-backup.env (root:root, 600).
# Il est chargé par /etc/cron.d/horizon-backup via BASH_ENV.
#
# NE COMMITTEZ JAMAIS le fichier /etc/horizon-backup.env (il contiendra des secrets).

# ===== Off-site (étape 5 — à remplir une fois le fournisseur choisi) =====
# Laisser vide tant que l'off-site n'est pas configuré : les scripts détectent
# l'absence des variables et sautent l'upload sans erreur.

# Si fournisseur = Backblaze B2 / Cloudflare R2 / S3 via rclone :
#   nom du remote rclone (configuré via `rclone config` côté root)
HORIZON_OFFSITE_RCLONE_REMOTE=
#   chemin distant (ex : "horizon-backups/prod")
HORIZON_OFFSITE_RCLONE_PATH=

# Si fournisseur = Azure Blob (style Astreos) :
HORIZON_OFFSITE_AZURE_ACCOUNT=
HORIZON_OFFSITE_AZURE_CONTAINER=
HORIZON_OFFSITE_AZURE_SAS_TOKEN=

# ===== Chiffrement off-site =====
# Clé publique age (https://age-encryption.org). Si vide, pas de chiffrement
# avant upload. Recommandé pour données financières (RGPD).
# Génération côté client : `age-keygen -o ~/horizon-backup.key` puis garder
# la clé privée HORS du serveur (cloud perso, gestionnaire de mots de passe).
HORIZON_OFFSITE_AGE_RECIPIENT=

# ===== Seuils et alertes =====
# Seuil disque (en %) à partir duquel disk-monitor.sh alerte.
HORIZON_DISK_THRESHOLD=85

# Adresse email pour alertes (si postfix configuré sur le serveur). Si vide,
# le cron MAILTO global s'applique.
HORIZON_BACKUP_MAILTO=
